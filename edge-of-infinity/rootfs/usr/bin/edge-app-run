#!/usr/bin/env bash
set -euo pipefail

source /usr/lib/bashio/bashio.sh

OPTIONS_PATH=/data/options.json

read_option() {
  local key="$1"
  local fallback="$2"

  if [[ -f "${OPTIONS_PATH}" ]]; then
    jq -er --arg key "${key}" --arg fallback "${fallback}" '.[$key] // $fallback' "${OPTIONS_PATH}" 2>/dev/null || echo "${fallback}"
  else
    echo "${fallback}"
  fi
}

LOG_LEVEL="$(read_option 'log_level' 'info')"
API_PORT="$(read_option 'api_port' '8088')"
RECORDINGS_DIR="$(read_option 'recordings_dir' '/media/edge-of-infinity/recordings')"
DATABASE_PATH="$(read_option 'database_path' '/homeassistant/edge/edge.db')"
RETENTION_DAYS="$(read_option 'retention_days' '14')"
INSTALL_CUSTOM_COMPONENT="$(read_option 'install_custom_component' 'true')"

LOG_LEVEL="${LOG_LEVEL:-info}"
API_PORT="${API_PORT:-8088}"
RECORDINGS_DIR="${RECORDINGS_DIR:-/media/edge-of-infinity/recordings}"
DATABASE_PATH="${DATABASE_PATH:-/homeassistant/edge/edge.db}"
RETENTION_DAYS="${RETENTION_DAYS:-14}"
INSTALL_CUSTOM_COMPONENT="${INSTALL_CUSTOM_COMPONENT:-true}"

if [[ "${DATABASE_PATH}" == "/config/edge.db" ]]; then
  DATABASE_PATH="/homeassistant/edge/edge.db"
fi

mkdir -p "${RECORDINGS_DIR}"
mkdir -p "$(dirname "${DATABASE_PATH}")"
mkdir -p /config
mkdir -p /homeassistant/edge
mkdir -p /homeassistant/edge/snapshots

install_custom_component() {
  local source_dir="/usr/share/edge-of-infinity/custom_components/edge"
  local target_dir="/homeassistant/custom_components/edge"

  if [[ "${INSTALL_CUSTOM_COMPONENT}" != "true" ]]; then
    bashio::log.info "Custom component auto-install is disabled."
    return
  fi

  if [[ ! -d "${source_dir}" ]]; then
    bashio::log.warning "Custom component source is missing: ${source_dir}"
    return
  fi

  if [[ ! -d /homeassistant ]]; then
    bashio::log.warning "Home Assistant config mount is missing. Cannot install custom component."
    return
  fi

  mkdir -p /homeassistant/custom_components
  rm -rf "${target_dir}"
  cp -R "${source_dir}" "${target_dir}"
  bashio::log.info "Installed Home Assistant custom component at ${target_dir}"
}

bashio::log.info "Starting Edge of Infinity"
bashio::log.info "Log level: ${LOG_LEVEL}"
bashio::log.info "API port: ${API_PORT}"
bashio::log.info "Recordings: ${RECORDINGS_DIR}"
bashio::log.info "Database: ${DATABASE_PATH}"
bashio::log.info "Retention days: ${RETENTION_DAYS}"
bashio::log.info "Install custom component: ${INSTALL_CUSTOM_COMPONENT}"

install_custom_component

EDGE_HOME_CONFIG=/homeassistant/edge/edge.json
EDGE_HOME_EXAMPLE_CONFIG=/homeassistant/edge/edge.example.json
EDGE_ADDON_CONFIG=/config/edge.json
EDGE_ADDON_EXAMPLE_CONFIG=/config/edge.example.json

cat > "${EDGE_HOME_EXAMPLE_CONFIG}" <<'EOF'
{
  "server": {
    "listen": "0.0.0.0:8088",
    "public_url": ""
  },
  "storage": {
    "recordings_dir": "/media/edge-of-infinity/recordings",
    "database_path": "/homeassistant/edge/edge.db",
    "retention_days": 14
  },
  "cameras": [
    {
      "id": "hikvision_1",
      "name": "Hikvision 1",
      "vendor": "hikvision",
      "host": "192.168.1.64",
      "username": "admin",
      "password": "change-me",
      "rtsp_main": "rtsp://admin:change-me@192.168.1.64:554/Streaming/Channels/101",
      "rtsp_sub": "rtsp://admin:change-me@192.168.1.64:554/Streaming/Channels/102",
      "onvif_url": "http://192.168.1.64:80/onvif/device_service",
      "isapi_base_url": "http://192.168.1.64",
      "enabled": false,
      "record": true,
      "low_latency": true,
      "snapshot_stream": "sub"
    },
    {
      "id": "hikvision_2",
      "name": "Hikvision 2",
      "vendor": "hikvision",
      "host": "192.168.1.65",
      "username": "admin",
      "password": "change-me",
      "rtsp_main": "rtsp://admin:change-me@192.168.1.65:554/Streaming/Channels/101",
      "rtsp_sub": "rtsp://admin:change-me@192.168.1.65:554/Streaming/Channels/102",
      "onvif_url": "http://192.168.1.65:80/onvif/device_service",
      "isapi_base_url": "http://192.168.1.65",
      "enabled": false,
      "record": true,
      "low_latency": true,
      "snapshot_stream": "sub"
    }
  ],
  "future_vendors": [
    "dahua",
    "onvif",
    "rtsp"
  ]
}
EOF
cp "${EDGE_HOME_EXAMPLE_CONFIG}" "${EDGE_ADDON_EXAMPLE_CONFIG}"

if [[ -f "${EDGE_HOME_CONFIG}" ]]; then
  EDGE_CONFIG="${EDGE_HOME_CONFIG}"
  bashio::log.info "Using Home Assistant camera config at ${EDGE_CONFIG}"
elif [[ -f "${EDGE_ADDON_CONFIG}" ]]; then
  EDGE_CONFIG="${EDGE_ADDON_CONFIG}"
  bashio::log.info "Using add-on camera config at ${EDGE_CONFIG}"
else
  EDGE_CONFIG="${EDGE_HOME_CONFIG}"
  bashio::log.info "Creating first-run camera config at ${EDGE_CONFIG}"
  cp "${EDGE_HOME_EXAMPLE_CONFIG}" "${EDGE_CONFIG}"
fi

if command -v edge-core >/dev/null 2>&1; then
  exec edge-core \
    -config "${EDGE_CONFIG}" \
    -listen "0.0.0.0:${API_PORT}" \
    -recordings-dir "${RECORDINGS_DIR}" \
    -database "${DATABASE_PATH}" \
    -retention-days "${RETENTION_DAYS}" \
    -log-level "${LOG_LEVEL}"
fi

bashio::log.warning "edge-core binary is not bundled yet."
bashio::log.warning "Running RTSP probe shell until the video engine is bundled."

mkdir -p /tmp/edge-placeholder
mkdir -p /tmp/edge-placeholder/snapshots

cat > /tmp/edge-placeholder/health <<'EOF'
{"status":"ok","product":"Edge of Infinity App placeholder","mode":"rtsp-probe-shell"}
EOF
cp /tmp/edge-placeholder/health /homeassistant/edge/health.json

generate_camera_status() {
  local output=/tmp/edge-placeholder/cameras.json.tmp
  local err=/tmp/edge-ffprobe.err
  local first=true

  printf '{"generated_at":"%s","cameras":[' "$(date -Iseconds)" > "${output}"

  if jq -e '.cameras' "${EDGE_CONFIG}" >/dev/null 2>&1; then
    while IFS= read -r camera; do
      local id name vendor host enabled record low_latency snapshot_stream rtsp rtsp_sub snapshot_rtsp
      local status detail codec width height fps safe_id snapshot_url snapshot_path
      id="$(jq -r '.id // "unknown"' <<< "${camera}")"
      name="$(jq -r '.name // .id // "Unknown camera"' <<< "${camera}")"
      vendor="$(jq -r '.vendor // "rtsp"' <<< "${camera}")"
      host="$(jq -r '.host // ""' <<< "${camera}")"
      enabled="$(jq -r '.enabled // false' <<< "${camera}")"
      record="$(jq -r '.record // false' <<< "${camera}")"
      low_latency="$(jq -r '.low_latency // false' <<< "${camera}")"
      snapshot_stream="$(jq -r '.snapshot_stream // "sub"' <<< "${camera}")"
      rtsp="$(jq -r '.rtsp_main // ""' <<< "${camera}")"
      rtsp_sub="$(jq -r '.rtsp_sub // ""' <<< "${camera}")"
      if [[ "${snapshot_stream}" == "main" ]]; then
        snapshot_rtsp="${rtsp}"
      else
        snapshot_stream="sub"
        snapshot_rtsp="${rtsp_sub}"
        if [[ -z "${snapshot_rtsp}" || "${snapshot_rtsp}" == "null" ]]; then
          snapshot_rtsp="${rtsp}"
        fi
      fi
      safe_id="$(printf '%s' "${id}" | tr -c 'A-Za-z0-9_.-' '_')"

      status="disabled"
      detail="Camera is configured but disabled."
      codec=""
      width=""
      height=""
      fps=""
      snapshot_url=""
      snapshot_path=""

      if [[ "${enabled}" == "true" ]]; then
        if [[ -z "${rtsp}" || "${rtsp}" == "null" ]]; then
          status="missing_rtsp"
          detail="Camera is enabled, but rtsp_main is empty."
        else
          : > "${err}"
          local probe_json
          probe_json="$(timeout 8 ffprobe -rtsp_transport tcp -v error -select_streams v:0 -show_entries stream=codec_name,width,height,r_frame_rate -of json "${rtsp}" 2>"${err}" || true)"
          if jq -e '.streams[0]' <<< "${probe_json}" >/dev/null 2>&1; then
            status="online"
            detail="RTSP main stream is reachable."
            codec="$(jq -r '.streams[0].codec_name // ""' <<< "${probe_json}")"
            width="$(jq -r '.streams[0].width // ""' <<< "${probe_json}")"
            height="$(jq -r '.streams[0].height // ""' <<< "${probe_json}")"
            fps="$(jq -r '.streams[0].r_frame_rate // ""' <<< "${probe_json}")"
            local tmp_snapshot="/tmp/edge-placeholder/snapshots/${safe_id}.jpg"
            if timeout 10 ffmpeg -rtsp_transport tcp -y -i "${snapshot_rtsp}" -frames:v 1 -q:v 4 "${tmp_snapshot}" >/dev/null 2>&1; then
              cp "${tmp_snapshot}" "/homeassistant/edge/snapshots/${safe_id}.jpg"
              snapshot_url="snapshots/${safe_id}.jpg"
              snapshot_path="snapshots/${safe_id}.jpg"
            fi
          else
            status="offline"
            detail="$(head -c 180 "${err}" | tr '\r\n' ' ')"
            detail="${detail:-RTSP probe failed. Check IP, credentials, port 554, and camera stream path.}"
          fi
        fi
      fi

      if [[ "${first}" == "true" ]]; then
        first=false
      else
        printf ',' >> "${output}"
      fi

      jq -n \
        --arg id "${id}" \
        --arg name "${name}" \
        --arg vendor "${vendor}" \
        --arg host "${host}" \
        --arg enabled "${enabled}" \
        --arg record "${record}" \
        --arg low_latency "${low_latency}" \
        --arg snapshot_stream "${snapshot_stream}" \
        --arg status "${status}" \
        --arg detail "${detail}" \
        --arg codec "${codec}" \
        --arg width "${width}" \
        --arg height "${height}" \
        --arg fps "${fps}" \
        --arg snapshot_url "${snapshot_url}" \
        --arg snapshot_path "${snapshot_path}" \
        '{
          id: $id,
          name: $name,
          vendor: $vendor,
          host: $host,
          enabled: ($enabled == "true"),
          record: ($record == "true"),
          low_latency: ($low_latency == "true"),
          snapshot_stream: $snapshot_stream,
          status: $status,
          detail: $detail,
          codec: $codec,
          width: $width,
          height: $height,
          fps: $fps,
          snapshot_url: $snapshot_url,
          snapshot_path: $snapshot_path
        }' >> "${output}"
    done < <(jq -c '.cameras[]?' "${EDGE_CONFIG}")
  fi

  printf ']}\n' >> "${output}"
  mv "${output}" /tmp/edge-placeholder/cameras.json
  cp /tmp/edge-placeholder/cameras.json /homeassistant/edge/cameras.json
}

generate_camera_status

cat > /tmp/edge-placeholder/index.html <<'EOF'
<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edge of Infinity</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #0b1014;
        --panel: #121a20;
        --panel-2: #17222a;
        --line: #273844;
        --text: #edf5f7;
        --muted: #9fb0ba;
        --accent: #56d6b5;
        --warn: #e4b45d;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background:
          linear-gradient(180deg, rgba(86, 214, 181, 0.08), transparent 280px),
          var(--bg);
        color: var(--text);
        font-family: system-ui, sans-serif;
      }
      main {
        width: min(1180px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 28px 0 40px;
      }
      header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
      }
      h1 {
        margin: 0 0 8px;
        font-size: clamp(28px, 6vw, 48px);
        line-height: 1;
      }
      p {
        margin: 0;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.5;
      }
      .status {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .pill {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 7px 10px;
        background: rgba(18, 26, 32, 0.84);
        color: var(--muted);
        font-size: 13px;
      }
      .pill strong {
        color: var(--text);
        font-weight: 650;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 14px;
      }
      .camera {
        min-height: 210px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: linear-gradient(180deg, var(--panel-2), var(--panel));
        overflow: hidden;
      }
      .preview {
        aspect-ratio: 16 / 9;
        display: grid;
        place-items: center;
        position: relative;
        background:
          linear-gradient(135deg, rgba(86, 214, 181, 0.12), transparent 45%),
          repeating-linear-gradient(90deg, rgba(255,255,255,0.035), rgba(255,255,255,0.035) 1px, transparent 1px, transparent 22px),
          #080d10;
        border-bottom: 1px solid var(--line);
      }
      .preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .preview span {
        color: var(--muted);
        font-size: 13px;
      }
      .body { padding: 14px; }
      .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      }
      .name {
        font-size: 17px;
        font-weight: 700;
        min-width: 0;
        overflow-wrap: anywhere;
      }
      .vendor {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 4px 8px;
        color: var(--accent);
        font-size: 12px;
        text-transform: uppercase;
      }
      .meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: 12px;
      }
      .metric {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 9px;
        background: rgba(0,0,0,0.14);
      }
      .metric b {
        display: block;
        margin-bottom: 3px;
        color: var(--muted);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
      }
      .metric span { font-size: 14px; }
      .state-enabled { color: var(--accent); }
      .state-disabled { color: var(--warn); }
      .notice {
        margin-top: 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 14px;
        background: rgba(18, 26, 32, 0.7);
      }
      code {
        color: var(--accent);
        overflow-wrap: anywhere;
      }
      @media (max-width: 720px) {
        header {
          align-items: start;
          flex-direction: column;
        }
        .status { justify-content: flex-start; }
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <div>
          <h1>Edge of Infinity</h1>
          <p>Private low-latency NVR shell. Hikvision-first, ready for multi-camera expansion.</p>
        </div>
        <div class="status">
          <div class="pill">Mode <strong>RTSP probe</strong></div>
          <div class="pill">Live <strong>WebRTC next</strong></div>
          <div class="pill">Vendors <strong>Hikvision, Dahua later</strong></div>
        </div>
      </header>

      <section class="grid" id="camera-grid"></section>

      <section class="notice">
        <p>Edit <code>/homeassistant/edge/edge.json</code> in File Editor to set your real Hikvision IPs, usernames, passwords, and RTSP URLs. In Home Assistant File Editor this is shown as <code>/config/edge/edge.json</code>. Set <code>enabled</code> to <code>true</code> for each real camera. This shell probes RTSP once at add-on start; WebRTC live comes next.</p>
      </section>
    </main>
    <script>
      const grid = document.getElementById('camera-grid');

      function text(value, fallback = 'unknown') {
        return value === undefined || value === null || value === '' ? fallback : value;
      }

      function cameraCard(camera) {
        const online = camera.status === 'online';
        const stateClass = online ? 'state-enabled' : 'state-disabled';
        const stateLabel = text(camera.status);
        const resolution = camera.width && camera.height ? `${camera.width}x${camera.height}` : 'unknown';
        const preview = camera.snapshot_url
          ? `<img src="${camera.snapshot_url}" alt="${text(camera.name, camera.id)} snapshot">`
          : `<span>${online ? 'RTSP reachable' : text(camera.detail, 'Waiting for camera')}</span>`;
        return `
          <article class="camera">
            <div class="preview">${preview}</div>
            <div class="body">
              <div class="row">
                <div class="name">${text(camera.name, camera.id)}</div>
                <div class="vendor">${text(camera.vendor)}</div>
              </div>
              <div class="meta">
                <div class="metric"><b>Host</b><span>${text(camera.host)}</span></div>
                <div class="metric"><b>Status</b><span class="${stateClass}">${stateLabel}</span></div>
                <div class="metric"><b>Video</b><span>${text(camera.codec)} ${resolution}</span></div>
                <div class="metric"><b>FPS</b><span>${text(camera.fps)}</span></div>
                <div class="metric"><b>Snapshot</b><span>${text(camera.snapshot_stream)}</span></div>
              </div>
            </div>
          </article>
        `;
      }

      fetch('cameras.json', { cache: 'no-store' })
        .then((response) => response.json())
        .then((data) => {
          const cameras = Array.isArray(data.cameras) ? data.cameras : [];
          grid.innerHTML = cameras.length
            ? cameras.map(cameraCard).join('')
            : '<p>No cameras configured yet.</p>';
        })
        .catch(() => {
          grid.innerHTML = '<p>Could not load camera configuration.</p>';
        });
    </script>
  </body>
</html>
EOF

exec darkhttpd /tmp/edge-placeholder --addr 0.0.0.0 --port "${API_PORT}"
