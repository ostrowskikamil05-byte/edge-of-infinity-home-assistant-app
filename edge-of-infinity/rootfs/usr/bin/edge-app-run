ADDON_OPTIONS_HASH_PATH=/homeassistant/edge/addon-options.hash
ADDON_OPTIONS_HASH="$(addon_camera_options_hash)"
PREVIOUS_ADDON_OPTIONS_HASH=""
if [[ -f "${ADDON_OPTIONS_HASH_PATH}" ]]; then
  PREVIOUS_ADDON_OPTIONS_HASH="$(cat "${ADDON_OPTIONS_HASH_PATH}")"
fi

if [[ -f "${EDGE_PANEL_CONFIG}" ]] && jq -e '.cameras | type == "array" and length > 0' "${EDGE_PANEL_CONFIG}" >/dev/null 2>&1; then
  EDGE_CONFIG="${EDGE_HOME_CONFIG}"
  cp "${EDGE_PANEL_CONFIG}" "${EDGE_HOME_CONFIG}"
  bashio::log.info "Using panel-authoritative camera config from ${EDGE_PANEL_CONFIG}."
elif has_addon_camera_options && [[ ! -f "${EDGE_HOME_CONFIG}" ]]; then
  EDGE_CONFIG="${EDGE_HOME_CONFIG}"
  write_addon_options_config "${EDGE_CONFIG}"
  echo "${ADDON_OPTIONS_HASH}" > "${ADDON_OPTIONS_HASH_PATH}"
  bashio::log.info "Created camera config from Home Assistant add-on options at ${EDGE_CONFIG}."
elif has_addon_camera_options && [[ -f "${EDGE_HOME_CONFIG}" ]]; then
  EDGE_CONFIG="${EDGE_HOME_CONFIG}"
  write_addon_options_config "${EDGE_OPTIONS_CONFIG}"
  echo "${ADDON_OPTIONS_HASH}" > "${ADDON_OPTIONS_HASH_PATH}"
  if [[ "${SYNC_ADDON_OPTIONS}" == "true" ]]; then
    bashio::log.warning "sync_addon_options is enabled, but panel config already exists. Keeping ${EDGE_CONFIG} as source of truth and writing add-on options only to ${EDGE_OPTIONS_CONFIG}."
  else
    bashio::log.info "Panel camera config already exists. Keeping ${EDGE_CONFIG} as source of truth."
  fi
elif [[ -f "${EDGE_HOME_CONFIG}" ]]; then
  EDGE_CONFIG="${EDGE_HOME_CONFIG}"
  bashio::log.info "Using Home Assistant camera config at ${EDGE_CONFIG}"
elif [[ -f "${EDGE_ADDON_CONFIG}" ]]; then
  EDGE_CONFIG="${EDGE_ADDON_CONFIG}"
  bashio::log.info "Using add-on camera config at ${EDGE_CONFIG}"
else
  EDGE_CONFIG="${EDGE_HOME_CONFIG}"
  bashio::log.info "Creating first-run camera config at ${EDGE_CONFIG}"
  cp "${EDGE_HOME_EXAMPLE_CONFIG}" "${EDGE_CONFIG}"
fi

MEDIAMTX_CONFIG=/tmp/edge-runtime/mediamtx.yml
JANUS_CONFIG_DIR=/tmp/edge-runtime/janus
MEDIAMTX_PID=""
JANUS_PID=""

cleanup_children() {
  if [[ -n "${JANUS_PID}" ]] && kill -0 "${JANUS_PID}" >/dev/null 2>&1; then
    kill "${JANUS_PID}" >/dev/null 2>&1 || true
  fi
  if [[ -n "${MEDIAMTX_PID}" ]] && kill -0 "${MEDIAMTX_PID}" >/dev/null 2>&1; then
    kill "${MEDIAMTX_PID}" >/dev/null 2>&1 || true
  fi
}
trap cleanup_children EXIT TERM INT

if [[ "${MEDIAMTX_ENABLED}" == "true" ]]; then
  if command -v mediamtx >/dev/null 2>&1; then
    generate_mediamtx_config "${MEDIAMTX_CONFIG}"
    bashio::log.info "Starting MediaMTX core on RTSP:${MEDIAMTX_RTSP_PORT}, LL-HLS:${MEDIAMTX_HLS_PORT}, WHEP:${MEDIAMTX_WEBRTC_PORT}, SRT:${MEDIAMTX_SRT_PORT}, API:${MEDIAMTX_API_PORT}"
    mediamtx "${MEDIAMTX_CONFIG}" &
    MEDIAMTX_PID="$!"
  else
    bashio::log.error "MediaMTX binary is missing. Live core will not start."
  fi
else
  bashio::log.warning "MediaMTX core is disabled in add-on options."
fi

if [[ "${JANUS_ENABLED}" == "true" ]]; then
  if command -v janus >/dev/null 2>&1; then
    generate_janus_config "${JANUS_CONFIG_DIR}"
    # Wait for MediaMTX RTSP to be ready before starting Janus streaming plugin
    # Janus streaming plugin tries to connect to RTSP at init time
    if [[ "${MEDIAMTX_ENABLED}" == "true" ]]; then
      bashio::log.info "Waiting for MediaMTX RTSP to be ready on port ${MEDIAMTX_RTSP_PORT}..."
      for _i in $(seq 1 15); do
        if nc -z 127.0.0.1 "${MEDIAMTX_RTSP_PORT}" 2>/dev/null; then
          bashio::log.info "MediaMTX RTSP is ready."
          break
        fi
        sleep 1
      done
    fi
    bashio::log.info "Starting Janus WebRTC gateway on HTTP:${JANUS_HTTP_PORT}, WS:${JANUS_WS_PORT}; streams are sourced from MediaMTX RTSP paths."
    janus --configs-folder="${JANUS_CONFIG_DIR}" --disable-colors &
    JANUS_PID="$!"
  else
    bashio::log.error "Janus binary is missing. WebRTC gateway will not start."
  fi
else
  bashio::log.warning "Janus WebRTC gateway is disabled in add-on options."
fi

bashio::log.info "Running Edge panel as controller for MediaMTX + Janus."

# The Python panel refreshes camera status before serving requests.

export EDGE_CONFIG
export EDGE_HOME_CONFIG
export EDGE_HOME_DIR=/homeassistant/edge
export EDGE_DATA_DIR=/tmp/edge-placeholder
export API_PORT
export EDGE_MEDIAMTX_ENABLED="${MEDIAMTX_ENABLED}"
export EDGE_MEDIAMTX_CONFIG="${MEDIAMTX_CONFIG}"
export EDGE_MEDIAMTX_HOST="127.0.0.1"
export EDGE_MEDIAMTX_RTSP_PORT="${MEDIAMTX_RTSP_PORT}"
export EDGE_MEDIAMTX_HLS_PORT="${MEDIAMTX_HLS_PORT}"
export EDGE_MEDIAMTX_WEBRTC_PORT="${MEDIAMTX_WEBRTC_PORT}"
export EDGE_MEDIAMTX_WEBRTC_UDP_PORT="${MEDIAMTX_WEBRTC_UDP_PORT}"
export EDGE_MEDIAMTX_WEBRTC_PUBLIC_HOSTS="${MEDIAMTX_WEBRTC_PUBLIC_HOSTS}"
export EDGE_MEDIAMTX_WEBRTC_STUN_URL="${MEDIAMTX_WEBRTC_STUN_URL}"
export EDGE_MEDIAMTX_WEBRTC_TURN_URL="${MEDIAMTX_WEBRTC_TURN_URL}"
export EDGE_MEDIAMTX_WEBRTC_TURN_USERNAME="${MEDIAMTX_WEBRTC_TURN_USERNAME}"
export EDGE_MEDIAMTX_SRT_PORT="${MEDIAMTX_SRT_PORT}"
export EDGE_MEDIAMTX_API_PORT="${MEDIAMTX_API_PORT}"
export EDGE_JANUS_ENABLED="${JANUS_ENABLED}"
export EDGE_JANUS_CONFIG_DIR="${JANUS_CONFIG_DIR}"
export EDGE_JANUS_HOST="127.0.0.1"
export EDGE_JANUS_HTTP_PORT="${JANUS_HTTP_PORT}"
export EDGE_JANUS_WS_PORT="${JANUS_WS_PORT}"

exec python3 /usr/share/edge-of-infinity/edge-panel.py
