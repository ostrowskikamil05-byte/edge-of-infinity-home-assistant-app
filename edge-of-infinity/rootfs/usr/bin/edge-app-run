#!/usr/bin/env bash
set -euo pipefail

source /usr/lib/bashio/bashio.sh

OPTIONS_PATH=/data/options.json

read_option() {
  local key="$1"
  local fallback="$2"

  if [[ -f "${OPTIONS_PATH}" ]]; then
    jq -r --arg key "${key}" --arg fallback "${fallback}" '.[$key] // $fallback' "${OPTIONS_PATH}" 2>/dev/null || echo "${fallback}"
  else
    echo "${fallback}"
  fi
}

LOG_LEVEL="$(read_option 'log_level' 'info')"
API_PORT="$(read_option 'api_port' '8088')"
RECORDINGS_DIR="$(read_option 'recordings_dir' '/media/edge-of-infinity/recordings')"
DATABASE_PATH="$(read_option 'database_path' '/homeassistant/edge/edge.db')"
RETENTION_DAYS="$(read_option 'retention_days' '14')"
INSTALL_CUSTOM_COMPONENT="$(read_option 'install_custom_component' 'true')"
SYNC_ADDON_OPTIONS="$(read_option 'sync_addon_options' 'false')"
CORE_ENGINE="$(read_option 'core_engine' 'mediamtx_janus')"
MEDIAMTX_ENABLED="$(read_option 'mediamtx_enabled' 'true')"
MEDIAMTX_RTSP_PORT="$(read_option 'mediamtx_rtsp_port' '8556')"
MEDIAMTX_HLS_PORT="$(read_option 'mediamtx_hls_port' '8888')"
MEDIAMTX_HLS_ALWAYS_REMUX="$(read_option 'mediamtx_hls_always_remux' 'false')"
MEDIAMTX_WEBRTC_PORT="$(read_option 'mediamtx_webrtc_port' '8889')"
MEDIAMTX_WEBRTC_UDP_PORT="$(read_option 'mediamtx_webrtc_udp_port' '8189')"
MEDIAMTX_WEBRTC_PUBLIC_HOSTS="$(read_option 'mediamtx_webrtc_public_hosts' 'homeassistant.local,192.168.33.17')"
MEDIAMTX_WEBRTC_STUN_URL="$(read_option 'mediamtx_webrtc_stun_url' 'stun:stun.l.google.com:19302')"
MEDIAMTX_WEBRTC_TURN_URL="$(read_option 'mediamtx_webrtc_turn_url' '')"
MEDIAMTX_WEBRTC_TURN_USERNAME="$(read_option 'mediamtx_webrtc_turn_username' '')"
MEDIAMTX_WEBRTC_TURN_PASSWORD="$(read_option 'mediamtx_webrtc_turn_password' '')"
MEDIAMTX_SRT_PORT="$(read_option 'mediamtx_srt_port' '8890')"
MEDIAMTX_API_PORT="$(read_option 'mediamtx_api_port' '9997')"
MEDIAMTX_RECORD="$(read_option 'mediamtx_record' 'true')"
JANUS_ENABLED="$(read_option 'janus_enabled' 'true')"
JANUS_HTTP_PORT="$(read_option 'janus_http_port' '8192')"
JANUS_WS_PORT="$(read_option 'janus_ws_port' '8193')"
JANUS_BUFFERKF_MS="$(read_option 'janus_bufferkf_ms' '2000')"

LOG_LEVEL="${LOG_LEVEL:-info}"
API_PORT="${API_PORT:-8088}"
RECORDINGS_DIR="${RECORDINGS_DIR:-/media/edge-of-infinity/recordings}"
DATABASE_PATH="${DATABASE_PATH:-/homeassistant/edge/edge.db}"
RETENTION_DAYS="${RETENTION_DAYS:-14}"
INSTALL_CUSTOM_COMPONENT="${INSTALL_CUSTOM_COMPONENT:-true}"
SYNC_ADDON_OPTIONS="${SYNC_ADDON_OPTIONS:-false}"
CORE_ENGINE="${CORE_ENGINE:-mediamtx_janus}"
MEDIAMTX_ENABLED="${MEDIAMTX_ENABLED:-true}"
MEDIAMTX_RTSP_PORT="${MEDIAMTX_RTSP_PORT:-8556}"
MEDIAMTX_HLS_PORT="${MEDIAMTX_HLS_PORT:-8888}"
MEDIAMTX_HLS_ALWAYS_REMUX="${MEDIAMTX_HLS_ALWAYS_REMUX:-false}"
MEDIAMTX_WEBRTC_PORT="${MEDIAMTX_WEBRTC_PORT:-8889}"
MEDIAMTX_WEBRTC_UDP_PORT="${MEDIAMTX_WEBRTC_UDP_PORT:-8189}"
MEDIAMTX_WEBRTC_PUBLIC_HOSTS="${MEDIAMTX_WEBRTC_PUBLIC_HOSTS:-homeassistant.local,192.168.33.17}"
MEDIAMTX_WEBRTC_STUN_URL="${MEDIAMTX_WEBRTC_STUN_URL:-stun:stun.l.google.com:19302}"
MEDIAMTX_WEBRTC_TURN_URL="${MEDIAMTX_WEBRTC_TURN_URL:-}"
MEDIAMTX_WEBRTC_TURN_USERNAME="${MEDIAMTX_WEBRTC_TURN_USERNAME:-}"
MEDIAMTX_WEBRTC_TURN_PASSWORD="${MEDIAMTX_WEBRTC_TURN_PASSWORD:-}"
MEDIAMTX_SRT_PORT="${MEDIAMTX_SRT_PORT:-8890}"
MEDIAMTX_API_PORT="${MEDIAMTX_API_PORT:-9997}"
MEDIAMTX_RECORD="${MEDIAMTX_RECORD:-true}"
JANUS_ENABLED="${JANUS_ENABLED:-true}"
JANUS_HTTP_PORT="${JANUS_HTTP_PORT:-8192}"
JANUS_WS_PORT="${JANUS_WS_PORT:-8193}"
JANUS_BUFFERKF_MS="${JANUS_BUFFERKF_MS:-2000}"

if [[ "${DATABASE_PATH}" == "/config/edge.db" ]]; then
  DATABASE_PATH="/homeassistant/edge/edge.db"
fi

mkdir -p "${RECORDINGS_DIR}"
mkdir -p "$(dirname "${DATABASE_PATH}")"
mkdir -p /config
mkdir -p /homeassistant/edge
mkdir -p /homeassistant/edge/snapshots
mkdir -p /tmp/edge-runtime
mkdir -p /tmp/edge-runtime/janus
mkdir -p /media/edge-of-infinity/recordings

install_custom_component() {
  local source_dir="/usr/share/edge-of-infinity/custom_components/edge"
  local target_dir="/homeassistant/custom_components/edge"

  if [[ "${INSTALL_CUSTOM_COMPONENT}" != "true" ]]; then
    bashio::log.info "Custom component auto-install is disabled."
    return
  fi

  if [[ ! -d "${source_dir}" ]]; then
    bashio::log.warning "Custom component source is missing: ${source_dir}"
    return
  fi

  if [[ ! -d /homeassistant ]]; then
    bashio::log.warning "Home Assistant config mount is missing. Cannot install custom component."
    return
  fi

  mkdir -p /homeassistant/custom_components
  rm -rf "${target_dir}"
  cp -R "${source_dir}" "${target_dir}"
  bashio::log.info "Installed Home Assistant custom component at ${target_dir}"
}

option_has_value() {
  local key="$1"
  local value

  value="$(read_option "${key}" "")"
  [[ -n "${value}" && "${value}" != "null" ]]
}

has_addon_camera_options() {
  option_has_value "hikvision_1_host" ||
    option_has_value "hikvision_1_rtsp_main" ||
    option_has_value "hikvision_2_host" ||
    option_has_value "hikvision_2_rtsp_main"
}

addon_camera_options_hash() {
  if [[ ! -f "${OPTIONS_PATH}" ]]; then
    echo ""
    return
  fi

  jq -c '{
    hikvision_1_enabled,
    hikvision_1_name,
    hikvision_1_host,
    hikvision_1_username,
    hikvision_1_password,
    hikvision_1_rtsp_main,
    hikvision_1_rtsp_sub,
    hikvision_1_onvif_url,
    hikvision_1_isapi_base_url,
    hikvision_1_record,
    hikvision_1_low_latency,
    hikvision_1_snapshot_stream,
    hikvision_1_live_stream,
    hikvision_1_record_stream,
    hikvision_2_enabled,
    hikvision_2_name,
    hikvision_2_host,
    hikvision_2_username,
    hikvision_2_password,
    hikvision_2_rtsp_main,
    hikvision_2_rtsp_sub,
    hikvision_2_onvif_url,
    hikvision_2_isapi_base_url,
    hikvision_2_record,
    hikvision_2_low_latency,
    hikvision_2_snapshot_stream,
    hikvision_2_live_stream,
    hikvision_2_record_stream
  }' "${OPTIONS_PATH}" 2>/dev/null | sha256sum | awk '{print $1}'
}

default_if_empty() {
  local value="$1"
  local fallback="$2"

  if [[ -n "${value}" && "${value}" != "null" ]]; then
    echo "${value}"
  else
    echo "${fallback}"
  fi
}

build_hikvision_rtsp() {
  local explicit="$1"
  local host="$2"
  local username="$3"
  local password="$4"
  local channel="$5"

  case "${channel}" in
    ''|*[!0-9]*) channel="102" ;;
  esac

  if [[ -n "${explicit}" && "${explicit}" != "null" ]]; then
    echo "${explicit}"
  elif [[ -n "${host}" && -n "${username}" && -n "${password}" ]]; then
    echo "rtsp://${username}:${password}@${host}:554/Streaming/Channels/${channel}"
  else
    echo ""
  fi
}

hikvision_channel_from_rtsp() {
  local value="$1"
  local fallback="$2"

  if [[ "${value}" =~ /Streaming/Channels/([0-9]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  else
    echo "${fallback}"
  fi
}

safe_path_id() {
  local value="$1"
  value="${value:-camera}"
  printf '%s' "${value}" | tr -c 'A-Za-z0-9_.-' '_'
}

csv_to_json_array() {
  local csv="$1"
  local result="[]"
  local item trimmed
  IFS=',' read -r -a items <<< "${csv}"
  for item in "${items[@]}"; do
    trimmed="$(printf '%s' "${item}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [[ -n "${trimmed}" ]]; then
      result="$(jq -c --arg value "${trimmed}" '. + [$value]' <<< "${result}")"
    fi
  done
  printf '%s' "${result}"
}

yaml_escape() {
  printf '%s' "${1:-}" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

runtime_live_option() {
  local key="$1"
  local fallback="$2"

  if [[ -n "${EDGE_CONFIG:-}" && -f "${EDGE_CONFIG}" ]]; then
    jq -r --arg key "${key}" --arg fallback "${fallback}" '
      if (.live? and .live[$key] != null and .live[$key] != "") then
        .live[$key] | tostring
      else
        $fallback
      end
    ' "${EDGE_CONFIG}" 2>/dev/null || printf '%s' "${fallback}"
  else
    printf '%s' "${fallback}"
  fi
}

numeric_or_fallback() {
  local value="$1"
  local fallback="$2"
  local minimum="${3:-0}"
  local maximum="${4:-100000}"

  if [[ ! "${value}" =~ ^[0-9]+$ ]]; then
    value="${fallback}"
  fi
  if (( value < minimum )); then
    value="${minimum}"
  elif (( value > maximum )); then
    value="${maximum}"
  fi
  printf '%s' "${value}"
}

build_mediamtx_ice_servers_yaml() {
  local stun_url="$1"
  local turn_url="$2"
  local turn_username="$3"
  local turn_password="$4"

  if [[ -z "${stun_url}" && -z "${turn_url}" ]]; then
    printf 'webrtcICEServers2: []\n'
    return
  fi

  printf 'webrtcICEServers2:\n'
  if [[ -n "${stun_url}" ]]; then
    printf '  - url: "%s"\n' "$(yaml_escape "${stun_url}")"
    printf '    username: ""\n'
    printf '    password: ""\n'
    printf '    clientOnly: false\n'
  fi
  if [[ -n "${turn_url}" ]]; then
    printf '  - url: "%s"\n' "$(yaml_escape "${turn_url}")"
    printf '    username: "%s"\n' "$(yaml_escape "${turn_username}")"
    printf '    password: "%s"\n' "$(yaml_escape "${turn_password}")"
    printf '    clientOnly: false\n'
  fi
}

write_mediamtx_path() {
  local output="$1"
  local path_name="$2"
  local source_url="$3"
  local should_record="$4"
  local keep_warm="${5:-false}"

  if [[ -z "${source_url}" || "${source_url}" == "null" ]]; then
    return
  fi

  {
    printf '  %s:\n' "${path_name}"
    printf '    source: "%s"\n' "${source_url}"
    printf '    rtspTransport: tcp\n'
    if [[ "${should_record}" == "true" && "${MEDIAMTX_RECORD}" == "true" ]]; then
      printf '    sourceOnDemand: no\n'
      printf '    record: yes\n'
      printf '    recordPath: "%s/%%path/%%Y-%%m-%%d_%%H-%%M-%%S-%%f"\n' "${RECORDINGS_DIR}"
    elif [[ "${keep_warm}" == "true" ]]; then
      printf '    sourceOnDemand: no\n'
      printf '    record: no\n'
    else
      printf '    sourceOnDemand: yes\n'
      printf '    sourceOnDemandStartTimeout: 15s\n'
      printf '    sourceOnDemandCloseAfter: 30s\n'
      printf '    record: no\n'
    fi
  } >> "${output}"
}

generate_mediamtx_config() {
  local output="$1"
  local public_hosts stun_url turn_url turn_username turn_password webrtc_public_hosts webrtc_ice_servers_yaml prebuffer_enabled
  public_hosts="$(runtime_live_option 'mobile_webrtc_public_hosts' "${MEDIAMTX_WEBRTC_PUBLIC_HOSTS}")"
  stun_url="$(runtime_live_option 'mobile_webrtc_stun_url' "${MEDIAMTX_WEBRTC_STUN_URL}")"
  turn_url="$(runtime_live_option 'mobile_webrtc_turn_url' "${MEDIAMTX_WEBRTC_TURN_URL}")"
  turn_username="$(runtime_live_option 'mobile_webrtc_turn_username' "${MEDIAMTX_WEBRTC_TURN_USERNAME}")"
  turn_password="$(runtime_live_option 'mobile_webrtc_turn_password' "${MEDIAMTX_WEBRTC_TURN_PASSWORD}")"
  prebuffer_enabled="$(runtime_live_option 'prebuffer_enabled' 'true')"
  webrtc_public_hosts="$(csv_to_json_array "${public_hosts}")"
  webrtc_ice_servers_yaml="$(build_mediamtx_ice_servers_yaml "${stun_url}" "${turn_url}" "${turn_username}" "${turn_password}")"
  cat > "${output}" <<EOF
logLevel: ${LOG_LEVEL}
logDestinations: [stdout]
readTimeout: 10s
writeTimeout: 10s
writeQueueSize: 512
udpMaxPayloadSize: 1452

api: yes
apiAddress: :${MEDIAMTX_API_PORT}

metrics: no
pprof: no
playback: yes
playbackAddress: :9996

rtsp: yes
rtspTransports: [tcp]
rtspEncryption: "no"
rtspAddress: :${MEDIAMTX_RTSP_PORT}

rtmp: no

hls: yes
hlsAddress: :${MEDIAMTX_HLS_PORT}
hlsAllowOrigins: ["*"]
hlsAlwaysRemux: ${MEDIAMTX_HLS_ALWAYS_REMUX}
hlsVariant: lowLatency
hlsSegmentCount: 4
hlsSegmentDuration: 1s
hlsPartDuration: 200ms
hlsSegmentMaxSize: 50M

webrtc: yes
webrtcAddress: :${MEDIAMTX_WEBRTC_PORT}
webrtcAllowOrigins: ["*"]
webrtcLocalUDPAddress: :${MEDIAMTX_WEBRTC_UDP_PORT}
webrtcLocalTCPAddress: :${MEDIAMTX_WEBRTC_UDP_PORT}
webrtcIPsFromInterfaces: no
webrtcAdditionalHosts: ${webrtc_public_hosts}
${webrtc_ice_servers_yaml}
webrtcSTUNGatherTimeout: 5s
webrtcHandshakeTimeout: 20s
webrtcTrackGatherTimeout: 5s

srt: yes
srtAddress: :${MEDIAMTX_SRT_PORT}

pathDefaults:
  sourceOnDemand: yes
  rtspTransport: tcp
  recordFormat: fmp4
  recordPartDuration: 1s
  recordSegmentDuration: 10s
  recordDeleteAfter: ${RETENTION_DAYS}d

paths:
EOF

  if jq -e '.cameras' "${EDGE_CONFIG}" >/dev/null 2>&1; then
    while IFS= read -r camera; do
      local id safe_id rtsp_main rtsp_sub enabled low_latency record tile_stream live_stream record_stream
      local record_main record_sub warm_main warm_sub
      id="$(jq -r '.id // "camera"' <<< "${camera}")"
      safe_id="$(safe_path_id "${id}")"
      rtsp_main="$(jq -r '.rtsp_main // ""' <<< "${camera}")"
      rtsp_sub="$(jq -r '.rtsp_sub // ""' <<< "${camera}")"
      enabled="$(jq -r '.enabled // false' <<< "${camera}")"
      low_latency="$(jq -r '.low_latency // true' <<< "${camera}")"
      record="$(jq -r '.record // false' <<< "${camera}")"
      tile_stream="$(jq -r '.tile_stream // "sub"' <<< "${camera}")"
      live_stream="$(jq -r '.live_stream // "sub"' <<< "${camera}")"
      record_stream="$(jq -r '.record_stream // "main"' <<< "${camera}")"
      record_main="$([[ "${enabled}" == "true" && "${record}" == "true" && "${record_stream}" != "sub" ]] && echo true || echo false)"
      record_sub="$([[ "${enabled}" == "true" && "${record}" == "true" && "${record_stream}" == "sub" ]] && echo true || echo false)"
      warm_main="$([[ "${enabled}" == "true" && "${low_latency}" == "true" && "${prebuffer_enabled}" == "true" && ( "${tile_stream}" == "main" || "${live_stream}" == "main" || "${record_main}" == "true" ) ]] && echo true || echo false)"
      warm_sub="$([[ "${enabled}" == "true" && "${low_latency}" == "true" && "${prebuffer_enabled}" == "true" && ( "${tile_stream}" == "sub" || "${live_stream}" == "sub" || "${record_sub}" == "true" ) ]] && echo true || echo false)"
      write_mediamtx_path "${output}" "${safe_id}_main" "${rtsp_main}" "${record_main}" "${warm_main}"
      write_mediamtx_path "${output}" "${safe_id}_sub" "${rtsp_sub}" "${record_sub}" "${warm_sub}"
    done < <(jq -c '.cameras[]?' "${EDGE_CONFIG}")
  fi
}

generate_janus_config() {
  local config_dir="$1"
  local streaming_config="${config_dir}/janus.plugin.streaming.jcfg"
  local bufferkf_ms
  bufferkf_ms="$(numeric_or_fallback "$(runtime_live_option 'prebuffer_remote_ms' "${JANUS_BUFFERKF_MS}")" "${JANUS_BUFFERKF_MS}" 0 10000)"

  mkdir -p "${config_dir}"
  cat > "${config_dir}/janus.jcfg" <<EOF
general: {
  configs_folder = "${config_dir}"
  plugins_folder = "/usr/lib/janus/plugins"
  transports_folder = "/usr/lib/janus/transports"
  events_folder = "/usr/lib/janus/events"
  log_to_stdout = true
  debug_level = 2
  daemonize = false
}
nat: {
  stun_server = "stun.l.google.com"
  stun_port = 19302
  nice_debug = false
}
media: {
  rtp_port_range = "20000-20100"
}
EOF

  cat > "${config_dir}/janus.transport.http.jcfg" <<EOF
general: {
  base_path = "/janus"
  http = true
  port = ${JANUS_HTTP_PORT}
  https = false
}
admin: {
  admin_base_path = "/admin"
  admin_http = true
  admin_port = 7188
  admin_https = false
}
EOF

  cat > "${config_dir}/janus.transport.websockets.jcfg" <<EOF
general: {
  ws = true
  ws_port = ${JANUS_WS_PORT}
  wss = false
}
admin: {
  admin_ws = false
}
EOF

  cat > "${streaming_config}" <<'EOF'
general: {
  admin_key = "edge-local"
}
EOF

  # recordplay plugin - needs recordings path or it will fail to init
  cat > "${config_dir}/janus.plugin.recordplay.jcfg" <<EOF
general: {
  path = "/tmp/edge-runtime/janus/recordings"
}
EOF
  mkdir -p /tmp/edge-runtime/janus/recordings

  if jq -e '.cameras' "${EDGE_CONFIG}" >/dev/null 2>&1; then
    local index=0
    while IFS= read -r camera; do
      local id name safe_id rtsp_main rtsp_sub main_id sub_id
      id="$(jq -r '.id // "camera"' <<< "${camera}")"
      name="$(jq -r '.name // .id // "Camera"' <<< "${camera}")"
      safe_id="$(safe_path_id "${id}")"
      rtsp_main="rtsp://127.0.0.1:${MEDIAMTX_RTSP_PORT}/${safe_id}_main"
      rtsp_sub="rtsp://127.0.0.1:${MEDIAMTX_RTSP_PORT}/${safe_id}_sub"
      main_id=$((10000 + (index * 10) + 1))
      sub_id=$((10000 + (index * 10) + 2))
      cat >> "${streaming_config}" <<EOF

${safe_id}_main: {
  type = "rtsp"
  id = ${main_id}
  description = "${name} main via MediaMTX"
  audio = false
  video = true
  url = "${rtsp_main}"
  rtsp_reconnect_delay = 3
  rtsp_timeout = 5
  rtsp_conn_timeout = 3
  rtsp_notify_changes = true
  bufferkf_ms = ${bufferkf_ms}
  playoutdelay_ext = true
}

${safe_id}_sub: {
  type = "rtsp"
  id = ${sub_id}
  description = "${name} sub via MediaMTX"
  audio = false
  video = true
  url = "${rtsp_sub}"
  rtsp_reconnect_delay = 3
  rtsp_timeout = 5
  rtsp_conn_timeout = 3
  rtsp_notify_changes = true
  bufferkf_ms = ${bufferkf_ms}
  playoutdelay_ext = true
}
EOF
      index=$((index + 1))
    done < <(jq -c '.cameras[]?' "${EDGE_CONFIG}")
  fi
}

write_addon_options_config() {
  local output="$1"
  local camera1_name camera1_host camera1_username camera1_password
  local camera1_rtsp_main camera1_rtsp_sub camera1_onvif camera1_isapi
  local camera1_enabled camera1_record camera1_low_latency camera1_snapshot_stream camera1_live_stream camera1_record_stream camera1_rtsp_sub_channel
  local camera2_name camera2_host camera2_username camera2_password
  local camera2_rtsp_main camera2_rtsp_sub camera2_onvif camera2_isapi
  local camera2_enabled camera2_record camera2_low_latency camera2_snapshot_stream camera2_live_stream camera2_record_stream camera2_rtsp_sub_channel

  camera1_name="$(read_option 'hikvision_1_name' 'Hikvision 1')"
  camera1_host="$(read_option 'hikvision_1_host' '')"
  camera1_username="$(read_option 'hikvision_1_username' 'admin')"
  camera1_password="$(read_option 'hikvision_1_password' '')"
  camera1_enabled="$(read_option 'hikvision_1_enabled' 'false')"
  camera1_record="$(read_option 'hikvision_1_record' 'true')"
  camera1_low_latency="$(read_option 'hikvision_1_low_latency' 'true')"
  camera1_snapshot_stream="$(read_option 'hikvision_1_snapshot_stream' 'sub')"
  camera1_live_stream="$(read_option 'hikvision_1_live_stream' 'sub')"
  camera1_record_stream="$(read_option 'hikvision_1_record_stream' 'main')"
  camera1_rtsp_main="$(build_hikvision_rtsp "$(read_option 'hikvision_1_rtsp_main' '')" "${camera1_host}" "${camera1_username}" "${camera1_password}" "101")"
  camera1_rtsp_sub="$(build_hikvision_rtsp "$(read_option 'hikvision_1_rtsp_sub' '')" "${camera1_host}" "${camera1_username}" "${camera1_password}" "102")"
  camera1_rtsp_sub_channel="$(hikvision_channel_from_rtsp "${camera1_rtsp_sub}" "102")"
  camera1_onvif="$(read_option 'hikvision_1_onvif_url' '')"
  camera1_isapi="$(read_option 'hikvision_1_isapi_base_url' '')"
  if [[ -n "${camera1_host}" ]]; then
    camera1_onvif="$(default_if_empty "${camera1_onvif}" "http://${camera1_host}:80/onvif/device_service")"
    camera1_isapi="$(default_if_empty "${camera1_isapi}" "http://${camera1_host}")"
  fi

  camera2_name="$(read_option 'hikvision_2_name' 'Hikvision 2')"
  camera2_host="$(read_option 'hikvision_2_host' '')"
  camera2_username="$(read_option 'hikvision_2_username' 'admin')"
  camera2_password="$(read_option 'hikvision_2_password' '')"
  camera2_enabled="$(read_option 'hikvision_2_enabled' 'false')"
  camera2_record="$(read_option 'hikvision_2_record' 'true')"
  camera2_low_latency="$(read_option 'hikvision_2_low_latency' 'true')"
  camera2_snapshot_stream="$(read_option 'hikvision_2_snapshot_stream' 'sub')"
  camera2_live_stream="$(read_option 'hikvision_2_live_stream' 'sub')"
  camera2_record_stream="$(read_option 'hikvision_2_record_stream' 'main')"
  camera2_rtsp_main="$(build_hikvision_rtsp "$(read_option 'hikvision_2_rtsp_main' '')" "${camera2_host}" "${camera2_username}" "${camera2_password}" "101")"
  camera2_rtsp_sub="$(build_hikvision_rtsp "$(read_option 'hikvision_2_rtsp_sub' '')" "${camera2_host}" "${camera2_username}" "${camera2_password}" "102")"
  camera2_rtsp_sub_channel="$(hikvision_channel_from_rtsp "${camera2_rtsp_sub}" "102")"
  camera2_onvif="$(read_option 'hikvision_2_onvif_url' '')"
  camera2_isapi="$(read_option 'hikvision_2_isapi_base_url' '')"
  if [[ -n "${camera2_host}" ]]; then
    camera2_onvif="$(default_if_empty "${camera2_onvif}" "http://${camera2_host}:80/onvif/device_service")"
    camera2_isapi="$(default_if_empty "${camera2_isapi}" "http://${camera2_host}")"
  fi

  jq -n \
    --arg listen "0.0.0.0:${API_PORT}" \
    --arg recordings_dir "${RECORDINGS_DIR}" \
    --arg database_path "${DATABASE_PATH}" \
    --arg retention_days "${RETENTION_DAYS}" \
    --arg camera1_name "${camera1_name}" \
    --arg camera1_host "${camera1_host}" \
    --arg camera1_username "${camera1_username}" \
    --arg camera1_password "${camera1_password}" \
    --arg camera1_rtsp_main "${camera1_rtsp_main}" \
    --arg camera1_rtsp_sub "${camera1_rtsp_sub}" \
    --arg camera1_onvif "${camera1_onvif}" \
    --arg camera1_isapi "${camera1_isapi}" \
    --arg camera1_enabled "${camera1_enabled}" \
    --arg camera1_record "${camera1_record}" \
    --arg camera1_low_latency "${camera1_low_latency}" \
    --arg camera1_snapshot_stream "${camera1_snapshot_stream}" \
    --arg camera1_live_stream "${camera1_live_stream}" \
    --arg camera1_record_stream "${camera1_record_stream}" \
    --arg camera1_rtsp_sub_channel "${camera1_rtsp_sub_channel}" \
    --arg camera2_name "${camera2_name}" \
    --arg camera2_host "${camera2_host}" \
    --arg camera2_username "${camera2_username}" \
    --arg camera2_password "${camera2_password}" \
    --arg camera2_rtsp_main "${camera2_rtsp_main}" \
    --arg camera2_rtsp_sub "${camera2_rtsp_sub}" \
    --arg camera2_onvif "${camera2_onvif}" \
    --arg camera2_isapi "${camera2_isapi}" \
    --arg camera2_enabled "${camera2_enabled}" \
    --arg camera2_record "${camera2_record}" \
    --arg camera2_low_latency "${camera2_low_latency}" \
    --arg camera2_snapshot_stream "${camera2_snapshot_stream}" \
    --arg camera2_live_stream "${camera2_live_stream}" \
    --arg camera2_record_stream "${camera2_record_stream}" \
    --arg camera2_rtsp_sub_channel "${camera2_rtsp_sub_channel}" \
    '{
      server: {
        listen: $listen,
        public_url: ""
      },
      storage: {
        recordings_dir: $recordings_dir,
        database_path: $database_path,
        retention_days: ($retention_days | tonumber)
      },
      cameras: [
        {
          id: "hikvision_1",
          name: $camera1_name,
          vendor: "hikvision",
          host: $camera1_host,
          username: $camera1_username,
          password: $camera1_password,
          rtsp_main: $camera1_rtsp_main,
          rtsp_sub: $camera1_rtsp_sub,
          rtsp_sub_channel: $camera1_rtsp_sub_channel,
          onvif_url: $camera1_onvif,
          isapi_base_url: $camera1_isapi,
          enabled: ($camera1_enabled == "true"),
          record: ($camera1_record == "true"),
          low_latency: ($camera1_low_latency == "true"),
          snapshot_stream: (if $camera1_snapshot_stream == "main" then "main" else "sub" end),
          live_stream: (if $camera1_live_stream == "main" then "main" else "sub" end),
          record_stream: (if $camera1_record_stream == "sub" then "sub" else "main" end)
        },
        {
          id: "hikvision_2",
          name: $camera2_name,
          vendor: "hikvision",
          host: $camera2_host,
          username: $camera2_username,
          password: $camera2_password,
          rtsp_main: $camera2_rtsp_main,
          rtsp_sub: $camera2_rtsp_sub,
          rtsp_sub_channel: $camera2_rtsp_sub_channel,
          onvif_url: $camera2_onvif,
          isapi_base_url: $camera2_isapi,
          enabled: ($camera2_enabled == "true"),
          record: ($camera2_record == "true"),
          low_latency: ($camera2_low_latency == "true"),
          snapshot_stream: (if $camera2_snapshot_stream == "main" then "main" else "sub" end),
          live_stream: (if $camera2_live_stream == "main" then "main" else "sub" end),
          record_stream: (if $camera2_record_stream == "sub" then "sub" else "main" end)
        }
      ],
      future_vendors: [
        "dahua",
        "onvif",
        "rtsp"
      ]
    }' > "${output}"
}

bashio::log.info "Starting Edge of Infinity"
bashio::log.info "Log level: ${LOG_LEVEL}"
bashio::log.info "API port: ${API_PORT}"
bashio::log.info "Recordings: ${RECORDINGS_DIR}"
bashio::log.info "Database: ${DATABASE_PATH}"
bashio::log.info "Retention days: ${RETENTION_DAYS}"
bashio::log.info "Install custom component: ${INSTALL_CUSTOM_COMPONENT}"

install_custom_component

EDGE_HOME_CONFIG=/homeassistant/edge/edge.json
EDGE_PANEL_CONFIG=/homeassistant/edge/panel-config.json
