#!/usr/bin/env bash
set -euo pipefail

source /usr/lib/bashio/bashio.sh

OPTIONS_PATH=/data/options.json

read_option() {
  local key="$1"
  local fallback="$2"

  if [[ -f "${OPTIONS_PATH}" ]]; then
    jq -r --arg key "${key}" --arg fallback "${fallback}" '.[$key] // $fallback' "${OPTIONS_PATH}" 2>/dev/null || echo "${fallback}"
  else
    echo "${fallback}"
  fi
}

LOG_LEVEL="$(read_option 'log_level' 'info')"
API_PORT="$(read_option 'api_port' '8088')"
RECORDINGS_DIR="$(read_option 'recordings_dir' '/media/edge-of-infinity/recordings')"
DATABASE_PATH="$(read_option 'database_path' '/homeassistant/edge/edge.db')"
RETENTION_DAYS="$(read_option 'retention_days' '14')"
INSTALL_CUSTOM_COMPONENT="$(read_option 'install_custom_component' 'true')"

LOG_LEVEL="${LOG_LEVEL:-info}"
API_PORT="${API_PORT:-8088}"
RECORDINGS_DIR="${RECORDINGS_DIR:-/media/edge-of-infinity/recordings}"
DATABASE_PATH="${DATABASE_PATH:-/homeassistant/edge/edge.db}"
RETENTION_DAYS="${RETENTION_DAYS:-14}"
INSTALL_CUSTOM_COMPONENT="${INSTALL_CUSTOM_COMPONENT:-true}"

if [[ "${DATABASE_PATH}" == "/config/edge.db" ]]; then
  DATABASE_PATH="/homeassistant/edge/edge.db"
fi

mkdir -p "${RECORDINGS_DIR}"
mkdir -p "$(dirname "${DATABASE_PATH}")"
mkdir -p /config
mkdir -p /homeassistant/edge
mkdir -p /homeassistant/edge/snapshots
mkdir -p /tmp/edge-runtime

install_custom_component() {
  local source_dir="/usr/share/edge-of-infinity/custom_components/edge"
  local target_dir="/homeassistant/custom_components/edge"

  if [[ "${INSTALL_CUSTOM_COMPONENT}" != "true" ]]; then
    bashio::log.info "Custom component auto-install is disabled."
    return
  fi

  if [[ ! -d "${source_dir}" ]]; then
    bashio::log.warning "Custom component source is missing: ${source_dir}"
    return
  fi

  if [[ ! -d /homeassistant ]]; then
    bashio::log.warning "Home Assistant config mount is missing. Cannot install custom component."
    return
  fi

  mkdir -p /homeassistant/custom_components
  rm -rf "${target_dir}"
  cp -R "${source_dir}" "${target_dir}"
  bashio::log.info "Installed Home Assistant custom component at ${target_dir}"
}

option_has_value() {
  local key="$1"
  local value

  value="$(read_option "${key}" "")"
  [[ -n "${value}" && "${value}" != "null" ]]
}

has_addon_camera_options() {
  option_has_value "hikvision_1_host" ||
    option_has_value "hikvision_1_rtsp_main" ||
    option_has_value "hikvision_2_host" ||
    option_has_value "hikvision_2_rtsp_main"
}

default_if_empty() {
  local value="$1"
  local fallback="$2"

  if [[ -n "${value}" && "${value}" != "null" ]]; then
    echo "${value}"
  else
    echo "${fallback}"
  fi
}

build_hikvision_rtsp() {
  local explicit="$1"
  local host="$2"
  local username="$3"
  local password="$4"
  local channel="$5"

  case "${channel}" in
    ''|*[!0-9]*) channel="102" ;;
  esac

  if [[ -n "${explicit}" && "${explicit}" != "null" ]]; then
    if [[ "${explicit}" == *"/Streaming/Channels/"* ]]; then
      echo "${explicit}" | sed -E "s#/Streaming/Channels/[0-9]+#/Streaming/Channels/${channel}#"
    else
      echo "${explicit}"
    fi
  elif [[ -n "${host}" && -n "${username}" && -n "${password}" ]]; then
    echo "rtsp://${username}:${password}@${host}:554/Streaming/Channels/${channel}"
  else
    echo ""
  fi
}

write_addon_options_config() {
  local output="$1"
  local camera1_name camera1_host camera1_username camera1_password
  local camera1_rtsp_main camera1_rtsp_sub camera1_onvif camera1_isapi
  local camera1_enabled camera1_record camera1_low_latency camera1_snapshot_stream camera1_record_stream camera1_rtsp_sub_channel
  local camera2_name camera2_host camera2_username camera2_password
  local camera2_rtsp_main camera2_rtsp_sub camera2_onvif camera2_isapi
  local camera2_enabled camera2_record camera2_low_latency camera2_snapshot_stream camera2_record_stream camera2_rtsp_sub_channel

  camera1_name="$(read_option 'hikvision_1_name' 'Hikvision 1')"
  camera1_host="$(read_option 'hikvision_1_host' '')"
  camera1_username="$(read_option 'hikvision_1_username' 'admin')"
  camera1_password="$(read_option 'hikvision_1_password' '')"
  camera1_enabled="$(read_option 'hikvision_1_enabled' 'false')"
  camera1_record="$(read_option 'hikvision_1_record' 'true')"
  camera1_low_latency="$(read_option 'hikvision_1_low_latency' 'true')"
  camera1_snapshot_stream="$(read_option 'hikvision_1_snapshot_stream' 'sub')"
  camera1_record_stream="$(read_option 'hikvision_1_record_stream' 'main')"
  camera1_rtsp_sub_channel="$(read_option 'hikvision_1_rtsp_sub_channel' '102')"
  camera1_rtsp_main="$(build_hikvision_rtsp "$(read_option 'hikvision_1_rtsp_main' '')" "${camera1_host}" "${camera1_username}" "${camera1_password}" "101")"
  camera1_rtsp_sub="$(build_hikvision_rtsp "$(read_option 'hikvision_1_rtsp_sub' '')" "${camera1_host}" "${camera1_username}" "${camera1_password}" "${camera1_rtsp_sub_channel}")"
  camera1_onvif="$(read_option 'hikvision_1_onvif_url' '')"
  camera1_isapi="$(read_option 'hikvision_1_isapi_base_url' '')"
  if [[ -n "${camera1_host}" ]]; then
    camera1_onvif="$(default_if_empty "${camera1_onvif}" "http://${camera1_host}:80/onvif/device_service")"
    camera1_isapi="$(default_if_empty "${camera1_isapi}" "http://${camera1_host}")"
  fi

  camera2_name="$(read_option 'hikvision_2_name' 'Hikvision 2')"
  camera2_host="$(read_option 'hikvision_2_host' '')"
  camera2_username="$(read_option 'hikvision_2_username' 'admin')"
  camera2_password="$(read_option 'hikvision_2_password' '')"
  camera2_enabled="$(read_option 'hikvision_2_enabled' 'false')"
  camera2_record="$(read_option 'hikvision_2_record' 'true')"
  camera2_low_latency="$(read_option 'hikvision_2_low_latency' 'true')"
  camera2_snapshot_stream="$(read_option 'hikvision_2_snapshot_stream' 'sub')"
  camera2_record_stream="$(read_option 'hikvision_2_record_stream' 'main')"
  camera2_rtsp_sub_channel="$(read_option 'hikvision_2_rtsp_sub_channel' '102')"
  camera2_rtsp_main="$(build_hikvision_rtsp "$(read_option 'hikvision_2_rtsp_main' '')" "${camera2_host}" "${camera2_username}" "${camera2_password}" "101")"
  camera2_rtsp_sub="$(build_hikvision_rtsp "$(read_option 'hikvision_2_rtsp_sub' '')" "${camera2_host}" "${camera2_username}" "${camera2_password}" "${camera2_rtsp_sub_channel}")"
  camera2_onvif="$(read_option 'hikvision_2_onvif_url' '')"
  camera2_isapi="$(read_option 'hikvision_2_isapi_base_url' '')"
  if [[ -n "${camera2_host}" ]]; then
    camera2_onvif="$(default_if_empty "${camera2_onvif}" "http://${camera2_host}:80/onvif/device_service")"
    camera2_isapi="$(default_if_empty "${camera2_isapi}" "http://${camera2_host}")"
  fi

  jq -n \
    --arg listen "0.0.0.0:${API_PORT}" \
    --arg recordings_dir "${RECORDINGS_DIR}" \
    --arg database_path "${DATABASE_PATH}" \
    --arg retention_days "${RETENTION_DAYS}" \
    --arg camera1_name "${camera1_name}" \
    --arg camera1_host "${camera1_host}" \
    --arg camera1_username "${camera1_username}" \
    --arg camera1_password "${camera1_password}" \
    --arg camera1_rtsp_main "${camera1_rtsp_main}" \
    --arg camera1_rtsp_sub "${camera1_rtsp_sub}" \
    --arg camera1_onvif "${camera1_onvif}" \
    --arg camera1_isapi "${camera1_isapi}" \
    --arg camera1_enabled "${camera1_enabled}" \
    --arg camera1_record "${camera1_record}" \
    --arg camera1_low_latency "${camera1_low_latency}" \
    --arg camera1_snapshot_stream "${camera1_snapshot_stream}" \
    --arg camera1_record_stream "${camera1_record_stream}" \
    --arg camera1_rtsp_sub_channel "${camera1_rtsp_sub_channel}" \
    --arg camera2_name "${camera2_name}" \
    --arg camera2_host "${camera2_host}" \
    --arg camera2_username "${camera2_username}" \
    --arg camera2_password "${camera2_password}" \
    --arg camera2_rtsp_main "${camera2_rtsp_main}" \
    --arg camera2_rtsp_sub "${camera2_rtsp_sub}" \
    --arg camera2_onvif "${camera2_onvif}" \
    --arg camera2_isapi "${camera2_isapi}" \
    --arg camera2_enabled "${camera2_enabled}" \
    --arg camera2_record "${camera2_record}" \
    --arg camera2_low_latency "${camera2_low_latency}" \
    --arg camera2_snapshot_stream "${camera2_snapshot_stream}" \
    --arg camera2_record_stream "${camera2_record_stream}" \
    --arg camera2_rtsp_sub_channel "${camera2_rtsp_sub_channel}" \
    '{
      server: {
        listen: $listen,
        public_url: ""
      },
      storage: {
        recordings_dir: $recordings_dir,
        database_path: $database_path,
        retention_days: ($retention_days | tonumber)
      },
      cameras: [
        {
          id: "hikvision_1",
          name: $camera1_name,
          vendor: "hikvision",
          host: $camera1_host,
          username: $camera1_username,
          password: $camera1_password,
          rtsp_main: $camera1_rtsp_main,
          rtsp_sub: $camera1_rtsp_sub,
          rtsp_sub_channel: $camera1_rtsp_sub_channel,
          onvif_url: $camera1_onvif,
          isapi_base_url: $camera1_isapi,
          enabled: ($camera1_enabled == "true"),
          record: ($camera1_record == "true"),
          low_latency: ($camera1_low_latency == "true"),
          snapshot_stream: (if $camera1_snapshot_stream == "main" then "main" else "sub" end),
          live_stream: "sub",
          record_stream: (if $camera1_record_stream == "sub" then "sub" else "main" end)
        },
        {
          id: "hikvision_2",
          name: $camera2_name,
          vendor: "hikvision",
          host: $camera2_host,
          username: $camera2_username,
          password: $camera2_password,
          rtsp_main: $camera2_rtsp_main,
          rtsp_sub: $camera2_rtsp_sub,
          rtsp_sub_channel: $camera2_rtsp_sub_channel,
          onvif_url: $camera2_onvif,
          isapi_base_url: $camera2_isapi,
          enabled: ($camera2_enabled == "true"),
          record: ($camera2_record == "true"),
          low_latency: ($camera2_low_latency == "true"),
          snapshot_stream: (if $camera2_snapshot_stream == "main" then "main" else "sub" end),
          live_stream: "sub",
          record_stream: (if $camera2_record_stream == "sub" then "sub" else "main" end)
        }
      ],
      future_vendors: [
        "dahua",
        "onvif",
        "rtsp"
      ]
    }' > "${output}"
}

bashio::log.info "Starting Edge of Infinity"
bashio::log.info "Log level: ${LOG_LEVEL}"
bashio::log.info "API port: ${API_PORT}"
bashio::log.info "Recordings: ${RECORDINGS_DIR}"
bashio::log.info "Database: ${DATABASE_PATH}"
bashio::log.info "Retention days: ${RETENTION_DAYS}"
bashio::log.info "Install custom component: ${INSTALL_CUSTOM_COMPONENT}"

install_custom_component

EDGE_HOME_CONFIG=/homeassistant/edge/edge.json
EDGE_HOME_EXAMPLE_CONFIG=/homeassistant/edge/edge.example.json
EDGE_ADDON_CONFIG=/config/edge.json
EDGE_ADDON_EXAMPLE_CONFIG=/config/edge.example.json
EDGE_OPTIONS_CONFIG=/tmp/edge-runtime/edge.options.json

cat > "${EDGE_HOME_EXAMPLE_CONFIG}" <<'EOF'
{
  "server": {
    "listen": "0.0.0.0:8088",
    "public_url": ""
  },
